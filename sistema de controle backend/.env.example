DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=controle_leite

# App
PORT=3001
HOST=0.0.0.0
NODE_ENV=production
FRONTEND_ORIGIN=http://10.1.1.33:3000

# Se estiver atrás de Nginx/Proxy com HTTPS, habilite isto
TRUST_PROXY=1

# Cookies de sessão
SESSION_COOKIE_NAME=sid
SESSION_COOKIE_SECURE=true
SESSION_SAME_SITE=lax

# Sessões
SESSION_SECRET=your_strong_secret_here
SESSION_TTL_MS=43200000

# Store de sessão: usa o MySQL do próprio sistema, sem Redis extra.
SESSION_TABLE_NAME=sessions

# Credenciais iniciais (seed)
AUTH_USER=admin
AUTH_PASSWORD=change_this_password